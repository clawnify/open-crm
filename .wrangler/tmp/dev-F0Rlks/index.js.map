{
  "facebook": {
    "authMode": "OAUTH2",
    "baseUrl": "https://graph.facebook.com"
  },
  "meta-marketing-api": {
    "authMode": "OAUTH2",
    "baseUrl": "https://graph.facebook.com",
    "aliasOf": "facebook"
  },
  "wordpress": {
    "authMode": "OAUTH2",
    "baseUrl": "https://public-api.wordpress.com/rest/v1"
  },
  "bird": {
    "authMode": "API_KEY",
    "baseUrl": "https://${connectionConfig.subdomain}.bird.com",
    "proxyHeaders": {
      "authorization": "AccessKey ${apiKey}"
    },
    "connectionConfigDefaults": {
      "subdomain": "api"
    }
  },
  "google-ads": {
    "authMode": "OAUTH2",
    "baseUrl": "https://googleads.googleapis.com",
    "aliasOf": "google"
  },
  "google": {
    "authMode": "OAUTH2",
    "baseUrl": "https://www.googleapis.com"
  }
}
